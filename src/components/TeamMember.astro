---
import type { Member } from '../data/team';

interface Props {
  member: Member;
  index: number;
}

const { member, index } = Astro.props;
const { name, role, bio, url } = member;

const num = String(index).padStart(2, '0');

// Blueprint-style monogram from the name — first letter of first two words,
// with a graceful fallback for the placeholder "[À compléter]" pattern.
const cleaned = name.replace(/[[\]]/g, '').trim();
const parts = cleaned.split(/\s+/).filter(Boolean);
const monogram =
  parts.length >= 2
    ? (parts[0][0] + parts[1][0]).toUpperCase()
    : (parts[0]?.[0] ?? '—').toUpperCase();

const Tag = url ? 'a' : 'div';
const linkAttrs = url
  ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<Tag class="member" {...linkAttrs}>
  <header class="member-head">
    <span class="idx mono">{num}</span>
    <span class="role mono">{role}</span>
  </header>

  <div class="member-body">
    <div class="avatar" aria-hidden="true">
      <span class="monogram">{monogram}</span>
    </div>
    <div class="member-text">
      <h3>{name}</h3>
      {bio && <p>{bio}</p>}
      {
        url && (
          <span class="member-link mono">
            Profil <span class="arrow">↗</span>
          </span>
        )
      }
    </div>
  </div>
</Tag>

<style>
  .member {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1.5px solid var(--ink);
    color: inherit;
    text-decoration: none;
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  a.member:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 0 var(--accent);
  }

  .member-head {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--space-2);
    border-bottom: 1.5px solid var(--ink);
  }

  .idx {
    display: grid;
    place-items: center;
    padding-inline: var(--space-2);
    background: var(--accent);
    color: var(--ink);
    font-weight: 700;
  }

  .role {
    display: flex;
    align-items: center;
    padding: 0.6rem var(--space-2);
    color: var(--muted);
  }

  .member-body {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3);
    align-items: flex-start;
  }

  .avatar {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    border: 1.5px solid var(--ink);
    background-color: var(--bg);
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 14px 14px;
    background-position: -1px -1px;
  }

  .monogram {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--step-1);
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .member-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .member-text h3 {
    margin: 0;
    font-size: var(--step-1);
  }

  .member-text p {
    margin: 0;
    color: var(--muted);
    font-size: var(--step-0);
  }

  .member-link {
    margin-top: var(--space-1);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink);
    font-weight: 700;
  }

  .arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease);
  }

  a.member:hover .arrow {
    transform: translate(2px, -2px);
  }
</style>
