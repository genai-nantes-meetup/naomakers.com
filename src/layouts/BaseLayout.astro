---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

// Association description reused for meta and structured data. Kept broad on
// purpose: Naomakers promotes the whole digital/tech ecosystem, not only Gen AI.
const orgDescription =
  "Naomakers est une association à but non lucratif qui promeut le secteur du numérique sur le territoire nantais et accompagne les personnes et les acteurs de l'écosystème technologique à travers hackathons, meetups et conférences.";

// JSON-LD: NGO + WebSite in a single @graph so search engines and AI answer
// engines (GEO) can extract the entity and its facts.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'NGO',
      '@id': 'https://naomakers.com/#organization',
      name: 'Naomakers',
      url: 'https://naomakers.com',
      email: 'team@naomakers.com',
      description: orgDescription,
      image: ogImage.href,
      areaServed: 'Nantes',
      location: {
        '@type': 'Place',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Nantes',
          addressCountry: 'FR',
        },
      },
      sameAs: [
        'https://www.meetup.com/generative-ai-nantes',
        'https://startupweekendnantes.fr',
        'https://shift-hackathon.com',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://naomakers.com/#website',
      name: 'Naomakers',
      url: 'https://naomakers.com',
      inLanguage: 'fr-FR',
      publisher: { '@id': 'https://naomakers.com/#organization' },
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />
    <meta name="author" content="Naomakers" />
    <meta name="theme-color" content="#fbfbf7" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Naomakers" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Naomakers — association nantaise pour le numérique et la tech"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23c6f000'/><g fill='%231a1b26'><rect x='24' y='24' width='16' height='52'/><rect x='60' y='24' width='16' height='52'/><polygon points='24,24 40,24 76,76 60,76'/></g></svg>"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
      is:inline
    />
  </head>
  <body>
    <slot />

    <footer class="footer">
      <div class="container">
        <div class="titleblock">
          <div class="field">
            <span class="mono label">Organisation</span>
            <span class="value">Naomakers</span>
          </div>
          <div class="field">
            <span class="mono label">Localisation</span>
            <span class="value">Nantes, FR</span>
          </div>
          <div class="field">
            <span class="mono label">Statut</span>
            <span class="value">Association loi 1901</span>
          </div>
          <div class="field">
            <span class="mono label">Depuis</span>
            <!-- Discreet contact: the "·" is a mailto to team@naomakers.com -->
            <span class="value"
              >2018<a
                class="contact-dot"
                href="mailto:team@naomakers.com"
                aria-label="Nous contacter">·</a
              ></span
            >
          </div>
        </div>
      </div>
    </footer>

    <style>
      .footer {
        margin-top: var(--space-8);
        padding-block: var(--space-4);
      }

      .titleblock {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1.5px solid var(--ink);
        background: var(--surface);
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: var(--space-2);
        border-right: 1px solid var(--border);
      }

      .field:last-child {
        border-right: 0;
      }

      .label {
        color: var(--muted);
      }

      .value {
        font-weight: 500;
      }

      .contact-dot {
        text-decoration: none;
        color: var(--muted);
        padding-inline: 0.25rem;
        opacity: 0.6;
        transition: opacity var(--dur) var(--ease);
      }

      .contact-dot:hover {
        opacity: 1;
        color: var(--ink);
      }

      @media (max-width: 640px) {
        .titleblock {
          grid-template-columns: 1fr 1fr;
        }

        .field:nth-child(2) {
          border-right: 0;
        }

        .field:nth-child(1),
        .field:nth-child(2) {
          border-bottom: 1px solid var(--border);
        }
      }
    </style>
  </body>
</html>
